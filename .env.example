# App
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database (Railway provides this automatically as $DATABASE_URL)
DATABASE_URL=postgresql://user:password@localhost:5432/tiktok_creator

# File storage
UPLOAD_DIR=app/static/uploads
MAX_UPLOAD_SIZE_MB=500

# Image generation — get free API key at huggingface.co
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# AI Video generation — get token at replicate.com
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# TikTok Developer App — developers.tiktok.com
TIKTOK_CLIENT_KEY=your_client_key
TIKTOK_CLIENT_SECRET=your_client_secret
TIKTOK_ACCESS_TOKEN=
